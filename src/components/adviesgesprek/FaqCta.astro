---
import Button from '../Button.astro';

interface Props {
	calLink?: string;
}

const { calLink } = Astro.props;
---

<section id="faq-cta" class="py-16 md:py-20 px-6 lg:px-8 bg-gradient-to-b from-white to-[var(--color-brand-base)] text-center fade-in-section">
	<div class="max-w-2xl mx-auto">
		<h2 class="text-2xl md:text-3xl font-semibold mb-4 tracking-tight">
			Klaar voor helderheid?
		</h2>
		<p class="text-lg text-[var(--color-brand-muted)] mb-8 leading-relaxed">
			Plan je adviesgesprek en ontdek wat er achter jouw klacht zit.
		</p>
		{calLink ? (
			<Button data-cal-link={calLink} data-cal-config='{"layout":"month_view","theme":"light"}' className="text-base md:text-lg px-8 py-4 cursor-pointer">
				Plan je adviesgesprek
			</Button>
		) : (
			<Button href="#kennismaking" className="text-base md:text-lg px-8 py-4">
				Plan je adviesgesprek
			</Button>
		)}
	</div>
</section>
