---
import Button from '../Button.astro';
import { Picture } from 'astro:assets';
import foto1 from '../../assets/images/foto_1.jpg';
---

{/* SECTIE 1 - HERO */}
<section id="hero" class="relative pt-12 pb-8 md:pt-24 md:pb-16 px-6 lg:px-8 max-w-7xl mx-auto flex flex-col-reverse lg:flex-row items-center gap-3 md:gap-12 lg:gap-0">
	<div class="w-full lg:w-[55%] relative z-20 text-center lg:text-left mt-2 md:mt-8 lg:mt-0 xl:-mr-24 bg-white/40 lg:bg-transparent backdrop-blur-md lg:backdrop-blur-none p-5 md:p-6 lg:p-0 rounded-3xl lg:rounded-none">
		<div class="inline-block px-4 py-2 rounded-full bg-[var(--color-brand-secondary)]/60 backdrop-blur-md border border-[var(--color-brand-secondary)] mb-3 md:mb-6 text-xs md:text-sm font-semibold tracking-widest uppercase text-[var(--color-brand-accent)] shadow-sm">
			Germaanse geneeskunde
		</div>
		<h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-[5rem] xl:text-[5.5rem] font-bold mb-4 md:mb-6 text-[var(--color-brand-primary-text)] leading-none md:leading-[1.05] tracking-tight drop-shadow-sm">
			Wat <span class="text-[var(--color-brand-accent)] relative inline-block italic decoration-[var(--color-brand-accent-light)]/40 underline underline-offset-[6px] decoration-[3px]">vertelt</span> jouw klacht je?
		</h1>
		<p class="text-lg sm:text-xl md:text-2xl text-[var(--color-brand-muted)] mb-5 md:mb-10 max-w-xl mx-auto lg:mx-0 leading-relaxed">
			Je klacht is niet willekeurig. Er zit een logica achter — een biologisch programma dat reageert op iets dat je hebt meegemaakt. Als je die logica begrijpt, begrijp je waarom je lichaam dit doet. En pas dan kun je er iets mee.
		</p>
		<div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
			<Button href="#wat-je-krijgt" className="text-base md:text-lg px-8 py-4 md:px-10 md:py-5 w-full sm:w-auto">
				Ontdek hoe dit werkt
			</Button>
			<a href="https://cal.com/crystalhelder/adviesgesprek" target="_blank" rel="noopener noreferrer" class="text-base md:text-lg text-[var(--color-brand-muted)] hover:text-[var(--color-brand-accent)] underline underline-offset-4 transition-colors duration-300 text-center sm:text-left self-center">
				Direct een adviesgesprek plannen — <s class="opacity-60">€47</s> €27
			</a>
		</div>
	</div>
	<div class="w-full lg:w-[50%] relative z-10">
		{/* Large Hero Image */}
		<div class="relative w-full max-w-[220px] sm:max-w-xs md:max-w-md mx-auto aspect-[3/4] sm:aspect-square md:aspect-square lg:aspect-[4/5]">
			<div class="absolute inset-0 bg-gradient-to-tr from-[#E8D1C5] via-[#f0ddd4] to-[#fdfbf9] rounded-tl-[6rem] rounded-br-[6rem] rounded-tr-3xl rounded-bl-3xl shadow-2xl shadow-[var(--color-brand-accent)]/25 transform rotate-[-2deg] transition-transform duration-700 hover:rotate-0"></div>

			{/* Foto 1 - The main heroic photo */}
			<Picture src={foto1} alt="Crystal GNM begeleiding" widths={[320, 480, 640, 960]} sizes="(max-width: 640px) 220px, (max-width: 768px) 320px, (max-width: 1024px) 448px, 640px" class="absolute inset-0 w-full h-full object-cover rounded-tl-[6rem] rounded-br-[6rem] rounded-tr-3xl rounded-bl-3xl shadow-[0_20px_50px_-15px_rgba(200,102,77,0.4)]" style="object-position: center 20%;" fetchpriority="high" loading="eager" />

		</div>
	</div>
</section>
