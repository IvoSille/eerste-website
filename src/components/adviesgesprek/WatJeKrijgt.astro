---
import Card from '../Card.astro';
import Button from '../Button.astro';
---

{/* SECTIE - WAT JE OVERHOUDT AAN DIT GESPREK */}
<section id="wat-je-krijgt" class="py-20 md:py-32 px-6 lg:px-8 bg-white relative fade-in-section">
	<div class="max-w-7xl mx-auto">
		<div class="text-center max-w-3xl mx-auto mb-16 md:mb-20">
			<h2 class="text-3xl sm:text-4xl md:text-5xl font-semibold mb-6 md:mb-8 leading-tight tracking-tight">
				Wat je overhoudt aan dit gesprek
			</h2>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
			<Card className="bg-[var(--color-brand-base)] hover:-translate-y-2 transition-all duration-500 ease-in-out border border-[#7A6F6C]/15 border-t-2 border-t-[var(--color-brand-accent)]/20 relative overflow-hidden group p-8 md:p-10 text-left shadow-sm hover:shadow-xl">
				<div class="relative z-10">
					<div class="text-[var(--color-brand-accent)] font-bold text-lg mb-3">→</div>
					<h3 class="text-xl md:text-2xl font-semibold mb-4 text-[var(--color-brand-primary-text)]">Helderheid over wat er speelt</h3>
					<p class="text-base md:text-lg text-[var(--color-brand-muted)] leading-relaxed">
						Je weet welk biologisch programma actief is en welk conflict eraan ten grondslag ligt. Geen vage vermoedens meer, maar een concrete duiding van jouw specifieke situatie.
					</p>
				</div>
			</Card>

			<Card className="bg-[var(--color-brand-base)] hover:-translate-y-2 transition-all duration-500 ease-in-out border border-[#7A6F6C]/15 border-t-2 border-t-[var(--color-brand-accent)]/20 relative overflow-hidden group p-8 md:p-10 text-left shadow-sm hover:shadow-xl">
				<div class="relative z-10">
					<div class="text-[var(--color-brand-accent)] font-bold text-lg mb-3">→</div>
					<h3 class="text-xl md:text-2xl font-semibold mb-4 text-[var(--color-brand-primary-text)]">Begrip van waar je staat in het proces</h3>
					<p class="text-base md:text-lg text-[var(--color-brand-muted)] leading-relaxed">
						Is het conflict nog actief, of zit je al in herstel? Wat betekent dat voor je klachten? Je begrijpt voor het eerst waarom je lichaam doet wat het doet.
					</p>
				</div>
			</Card>

			<Card className="bg-[var(--color-brand-base)] hover:-translate-y-2 transition-all duration-500 ease-in-out border border-[#7A6F6C]/15 border-t-2 border-t-[var(--color-brand-accent)]/20 relative overflow-hidden group p-8 md:p-10 text-left shadow-sm hover:shadow-xl">
				<div class="relative z-10">
					<div class="text-[var(--color-brand-accent)] font-bold text-lg mb-3">→</div>
					<h3 class="text-xl md:text-2xl font-semibold mb-4 text-[var(--color-brand-primary-text)]">Een eerlijk beeld van hoe je verder kunt</h3>
					<p class="text-base md:text-lg text-[var(--color-brand-muted)] leading-relaxed">
						Soms is één gesprek genoeg. Soms is er meer nodig. Ik ben daar eerlijk over — ik adviseer nooit meer dan nodig is.
					</p>
				</div>
			</Card>
		</div>

		<div class="text-center mt-12 md:mt-16">
			<p class="text-sm md:text-base font-semibold tracking-widest uppercase text-[var(--color-brand-accent)] mb-3">Tijdelijk</p>
			<p class="text-4xl md:text-5xl font-bold text-[var(--color-brand-primary-text)] mb-2"><s class="text-2xl md:text-3xl text-[var(--color-brand-muted)] opacity-50 font-normal">€47</s> €27</p>
			<p class="text-base md:text-lg text-[var(--color-brand-muted)] mb-6 italic">De drempel is bewust laag. De waarde niet.</p>
			<Button data-cal-link="crystalhelder/adviesgesprek" data-cal-config='{"layout":"month_view","theme":"light"}' className="text-base md:text-lg px-8 py-4 md:px-10 md:py-5 cursor-pointer">
				Plan je adviesgesprek
			</Button>
		</div>
	</div>
</section>
