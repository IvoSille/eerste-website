---
import Card from '../Card.astro';
import Button from '../Button.astro';
---

{/* NIEUWE SECTIE - ZO WERKT HET */}
<section class="py-20 md:py-32 px-6 lg:px-8 bg-gradient-to-b from-[var(--color-brand-sage)]/10 via-[var(--color-brand-sage)]/20 to-transparent relative fade-in-section">
	<div class="max-w-7xl mx-auto">
		<div class="text-center max-w-3xl mx-auto mb-16 md:mb-20">
			<h2 class="text-3xl sm:text-4xl md:text-5xl font-semibold mb-6 md:mb-8 leading-tight tracking-tight">
				Zo werkt het
			</h2>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
			<Card className="bg-[var(--color-brand-base)] hover:-translate-y-2 transition-all duration-500 ease-in-out border border-[#7A6F6C]/15 border-t-2 border-t-[var(--color-brand-accent)]/20 relative overflow-hidden group p-8 md:p-12 text-left shadow-sm hover:shadow-xl">
				{/* Large background number */}
				<div class="absolute -right-6 -bottom-10 md:-right-8 md:-bottom-12 text-[12rem] md:text-[16rem] font-light text-[#7A6F6C] opacity-[0.08] group-hover:opacity-[0.14] leading-none select-none pointer-events-none transition-opacity duration-500" style="font-family: 'Outfit', sans-serif;">
					1
				</div>
				<div class="relative z-10 pt-2 md:pt-4">
					<h3 class="text-2xl md:text-3xl font-semibold mb-4 md:mb-6 text-[var(--color-brand-primary-text)]">Je plant je adviesgesprek</h3>
					<p class="text-lg text-[var(--color-brand-muted)] leading-relaxed">
						Kies een moment dat je uitkomt en vertel kort over je klacht. Zo kan ik me voorbereiden.
					</p>
				</div>
			</Card>

			<Card className="bg-[var(--color-brand-base)] hover:-translate-y-2 transition-all duration-500 ease-in-out border border-[#7A6F6C]/15 border-t-2 border-t-[var(--color-brand-accent)]/20 relative overflow-hidden group p-8 md:p-12 text-left shadow-sm hover:shadow-xl">
				{/* Large background number */}
				<div class="absolute -right-6 -bottom-10 md:-right-8 md:-bottom-12 text-[12rem] md:text-[16rem] font-light text-[#7A6F6C] opacity-[0.08] group-hover:opacity-[0.14] leading-none select-none pointer-events-none transition-opacity duration-500" style="font-family: 'Outfit', sans-serif;">
					2
				</div>
				<div class="relative z-10 pt-2 md:pt-4">
					<h3 class="text-2xl md:text-3xl font-semibold mb-4 md:mb-6 text-[var(--color-brand-primary-text)]">We kijken samen naar jouw situatie</h3>
					<p class="text-lg text-[var(--color-brand-muted)] leading-relaxed">
						In 30 minuten analyseer ik wat er speelt op basis van de vijf biologische natuurwetten. Je krijgt inzicht in welk conflict er actief is en in welke fase je je bevindt.
					</p>
				</div>
			</Card>

			<Card className="bg-[var(--color-brand-base)] hover:-translate-y-2 transition-all duration-500 ease-in-out border border-[#7A6F6C]/15 border-t-2 border-t-[var(--color-brand-accent)]/20 relative overflow-hidden group p-8 md:p-12 text-left shadow-sm hover:shadow-xl">
				{/* Large background number */}
				<div class="absolute -right-6 -bottom-10 md:-right-8 md:-bottom-12 text-[12rem] md:text-[16rem] font-light text-[#7A6F6C] opacity-[0.08] group-hover:opacity-[0.14] leading-none select-none pointer-events-none transition-opacity duration-500" style="font-family: 'Outfit', sans-serif;">
					3
				</div>
				<div class="relative z-10 pt-2 md:pt-4">
					<h3 class="text-2xl md:text-3xl font-semibold mb-4 md:mb-6 text-[var(--color-brand-primary-text)]">Je weet waar je staat — en hoe verder</h3>
					<p class="text-lg text-[var(--color-brand-muted)] leading-relaxed">
						Na het gesprek heb je helderheid over wat er speelt en wat voor jou een logische weg vooruit is.
					</p>
				</div>
			</Card>
		</div>

		<div class="text-center mt-12 md:mt-16">
			<Button data-cal-link="crystalhelder/adviesgesprek" data-cal-config='{"layout":"month_view","theme":"light"}' className="text-base md:text-lg px-8 py-4 md:px-10 md:py-5 cursor-pointer">
				Plan je adviesgesprek — €47
			</Button>
		</div>
	</div>
</section>
