---
import "../styles/global.css";
import ConsentBanner from "../components/ConsentBanner.astro";

interface Props {
	title: string;
	description?: string;
	includeCal?: boolean;
	calLink?: string;
	bedanktUrl?: string;
	conversionEvent?: string;
	conversionValue?: number;
	conversionCurrency?: string;
}

const {
	title,
	description = "Persoonlijke begeleiding bij klachten en symptomen op basis van de Germaanse Geneeskunde.",
	includeCal = true,
	calLink = "crystalhelder/kennismaking",
	bedanktUrl = "/germaanse-geneeskunde-begeleiding/bedankt/",
	conversionEvent = "generate_lead",
	conversionValue = 0,
	conversionCurrency = "EUR",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="nl">
	<head>
		<script is:inline>
			document.documentElement.classList.add("js");
		</script>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO & Open Graph Meta Tags -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:image" content={new URL('/og-image.jpg', Astro.site)} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL('/og-image.jpg', Astro.site)} />
		<link rel="canonical" href={Astro.url} />

		<!-- Preload critical self-hosted fonts -->
		<link
			rel="preload"
			href="/fonts/outfit-latin.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>
		<link
			rel="preload"
			href="/fonts/lato-400-latin.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>
		<link
			rel="preload"
			href="/fonts/lato-700-latin.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>

		<title>{title}</title>

		{/* Cal.com Embed Script (deferred until first user interaction) */}
		{includeCal &&
		<script is:inline define:vars={{ __calLink: calLink, __bedanktUrl: bedanktUrl, __conversionEvent: conversionEvent, __conversionValue: conversionValue, __conversionCurrency: conversionCurrency }}>
			(function (C, A, L) {
				let p = function (a, ar) { a.q.push(ar); };
				let d = C.document;
				C.Cal = C.Cal || function () {
					let cal = C.Cal;
					let ar = arguments;
					if (!cal.loaded) {
						cal.ns = {};
						cal.q = cal.q || [];
						cal.loaded = true;
					}
					if (ar[0] === L) {
						const api = function () { p(api, arguments); };
						const namespace = ar[1];
						api.q = api.q || [];
						if (typeof namespace === "string") {
							cal.ns[namespace] = cal.ns[namespace] || api;
							p(cal.ns[namespace], ar);
							p(cal, ["initNamespace", namespace]);
						} else p(cal, ar);
						return;
					}
					p(cal, ar);
				};
				var el = false;
				function load() {
					if (el) return;
					el = true;
					d.head.appendChild(d.createElement("script")).src = A;
					["mousemove","touchstart","scroll","keydown"].forEach(function(e) {
						d.removeEventListener(e, load, true);
					});
				}
				["mousemove","touchstart","scroll","keydown"].forEach(function(e) {
					d.addEventListener(e, load, { capture: true, passive: true });
				});
			})(window, "https://app.cal.com/embed/embed.js", "init");
			Cal("init", { origin: "https://app.cal.com" });
			Cal("preload", { calLink: __calLink });
			Cal("on", {
				action: "bookingSuccessful",
				callback: function () {
					var redirectUrl = __bedanktUrl;
					var hasRedirected = false;
					function doRedirect() {
						if (!hasRedirected) {
							hasRedirected = true;
							window.location.href = redirectUrl;
						}
					}
					// Notify n8n → ntfy (fire-and-forget, mag redirect niet blokkeren)
					try {
						fetch("https://n8n.reconnectnow.nl/webhook/cal-booking", {
							method: "POST",
							headers: { "Content-Type": "application/json" },
							body: JSON.stringify({ event: "booking_successful", source: "crystalhelder.nl", timestamp: new Date().toISOString() }),
							keepalive: true
						}).catch(function() {});
					} catch(e) {}
					window.dataLayer = window.dataLayer || [];
					var eventData = {
						event: __conversionEvent,
						lead_source: "cal_booking",
						eventCallback: doRedirect,
						eventTimeout: 2000,
					};
					if (__conversionValue > 0) {
						eventData.value = __conversionValue;
						eventData.currency = __conversionCurrency;
						eventData.transaction_id = __conversionEvent + "_" + Date.now();
					}
					window.dataLayer.push(eventData);
					setTimeout(doRedirect, 2500);
				},
			});
		</script>
		}

		<!-- Google Consent Mode v2 defaults (MUST load before GTM) -->
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				dataLayer.push(arguments);
			}
			gtag("consent", "default", {
				ad_storage: "denied",
				ad_user_data: "denied",
				ad_personalization: "denied",
				analytics_storage: "denied",
				wait_for_update: 500,
			});
			// Restore previous consent choice if still valid (6 months)
			// NOTE: Same validation logic exists in ConsentBanner.astro — keep both in sync
			(function () {
				try {
					var stored = localStorage.getItem("cookie_consent");
					if (stored) {
						var data = JSON.parse(stored);
						var sixMonths = 180 * 24 * 60 * 60 * 1000;
						if (
							data.timestamp &&
							Date.now() - data.timestamp < sixMonths
						) {
							if (data.choice === "granted") {
								gtag("consent", "update", {
									ad_storage: "granted",
									ad_user_data: "granted",
									ad_personalization: "granted",
									analytics_storage: "granted",
								});
							}
						} else {
							localStorage.removeItem("cookie_consent");
						}
					}
				} catch (e) {}
			})();
		</script>

		<!-- Google Tag Manager via Stape Custom Loader -->
		<script is:inline>
			(function (w, d, s, l, i) {
				w[l] = w[l] || [];
				w[l].push({
					"gtm.start": new Date().getTime(),
					event: "gtm.js",
				});
				var f = d.getElementsByTagName(s)[0],
					j = d.createElement(s);
				j.async = true;
				j.src =
					"https://ss.crystalhelder.nl/bakhobnkjj.js?" + i;
				f.parentNode.insertBefore(j, f);
			})(
				window,
				document,
				"script",
				"dataLayer",
				"8y=Aw5WKTYiRSYtXCM4KT9fTRxXWUBTSQwFVwkZFxEbCQcCDwcKBx1GBQY%3D"
			);
		</script>
	</head>
	<body
		class="bg-[var(--color-brand-base)] text-[var(--color-brand-primary-text)] antialiased font-sans text-lg selection:bg-[var(--color-brand-accent)] selection:text-white"
	>
		<!-- Google Tag Manager (noscript) via Stape -->
		<noscript
			><iframe
				src="https://ss.crystalhelder.nl/ns.html?id=GTM-MG6HVKP7"
				height="0"
				width="0"
				style="display:none;visibility:hidden"></iframe>
		</noscript>
		<slot />
		<ConsentBanner />
	</body>
</html>
