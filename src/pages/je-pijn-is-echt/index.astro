	}
	:global(html.js) .fade-in-section.is-visible {
		opacity: 1;
		transform: none;
		visibility: visible;
	}
</style>

<style>
	/* FAQ Accordion Animation */
	details > summary {
		list-style: none;
	}
	details > summary::-webkit-details-marker {
		display: none;
	}

	.faq-content {
		display: grid;
		grid-template-rows: 0fr;
		opacity: 0;
		transition:
			grid-template-rows 400ms ease-out,
			opacity 400ms ease-out;
		will-change: grid-template-rows, opacity;
	}

	.faq-content > div {
		overflow: hidden;
	}

	details[open] .faq-content {
		grid-template-rows: 1fr;
		opacity: 1;
	}

	/* Subtiele tail aan de WhatsApp-berichtbubbel (linksboven) */
	.chat-bubble::before {
		content: "";
		position: absolute;
		top: 0;
		left: -7px;
		width: 0;
		height: 0;
		border-style: solid;
		border-width: 0 9px 11px 0;
		border-color: transparent #ffffff transparent transparent;
	}
</style>

<script>
	// Scroll animation observer
	document.addEventListener("DOMContentLoaded", () => {
		const observer = new IntersectionObserver(
			(entries, obs) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add("is-visible");
						obs.unobserve(entry.target);
					}
				});
			},
			{ threshold: 0.15 }
		);
		document
			.querySelectorAll(".fade-in-section")
			.forEach((el) => observer.observe(el));
	});

	// Scroll depth tracking
	document.addEventListener("DOMContentLoaded", () => {
		const thresholds = [25, 50, 75, 90];
		const fired = new Set<number>();

		const checkScroll = () => {
			const scrollTop = window.scrollY;
			const docHeight =
				document.documentElement.scrollHeight - window.innerHeight;
			if (docHeight <= 0) return;
			const scrollPercent = Math.round((scrollTop / docHeight) * 100);

			thresholds.forEach((threshold) => {
				if (scrollPercent >= threshold && !fired.has(threshold)) {
					fired.add(threshold);
					window.dataLayer = window.dataLayer || [];
					window.dataLayer.push({
						event: "scroll_depth",
						scroll_percentage: threshold,
					});
				}
			});
		};

		let ticking = false;
		window.addEventListener(
			"scroll",
			() => {
				if (!ticking) {
					window.requestAnimationFrame(() => {
						checkScroll();
						ticking = false;
					});
					ticking = true;
				}
			},
			{ passive: true }
		);
	});

	// CTA click tracking (alle "doe mee"-knoppen → opt-in sectie)
	document.addEventListener("DOMContentLoaded", () => {
		document.addEventListener("click", (e) => {
			const el = (e.target as HTMLElement).closest('a[href="#doe-mee"]');
			if (!el) return;
			window.dataLayer = window.dataLayer || [];
			window.dataLayer.push({
				event: "cta_click",
				cta_text: el.textContent?.trim() || "",
				cta_destination: "doe-mee",
				cta_location:
					el.getAttribute("data-cta-location") ||
					el.closest("section")?.id ||
					"hero",
			});
		});
	});

	// FAQ accordion
	document.addEventListener("DOMContentLoaded", () => {
		const detailsElements = document.querySelectorAll("details");
		detailsElements.forEach((targetDetail) => {
			targetDetail.addEventListener("click", (e) => {
				const target = e.target as HTMLElement;
				if (target.tagName !== "SUMMARY" && !target.closest("summary")) return;

				e.preventDefault();

				if (targetDetail.hasAttribute("open")) {
					const content = targetDetail.querySelector(
						".faq-content"
					) as HTMLElement;
					content.style.opacity = "0";
					content.style.gridTemplateRows = "0fr";
					setTimeout(() => {
						targetDetail.removeAttribute("open");
					}, 400);
				} else {
					// Close others (accordion)
					detailsElements.forEach((detail) => {
						if (detail !== targetDetail && detail.hasAttribute("open")) {
							const content = detail.querySelector(
								".faq-content"
							) as HTMLElement;
							content.style.opacity = "0";
							content.style.gridTemplateRows = "0fr";
							setTimeout(() => {
								detail.removeAttribute("open");
							}, 400);
						}
					});

					targetDetail.setAttribute("open", "");

					// Track FAQ open
					const questionText =
						targetDetail.querySelector("summary span")?.textContent?.trim() ||
						"";
					window.dataLayer = window.dataLayer || [];
					window.dataLayer.push({
						event: "faq_open",
						faq_question: questionText,
					});

					const content = targetDetail.querySelector(
						".faq-content"
					) as HTMLElement;
					content.getBoundingClientRect();
					content.style.opacity = "1";
					content.style.gridTemplateRows = "1fr";
				}
			});
		});
	});

	// Opt-in form submission
	document.addEventListener("DOMContentLoaded", () => {
		const form = document.getElementById("optin-form") as HTMLFormElement | null;
		if (!form) return;
		const errorEl = document.getElementById("form-error") as HTMLElement;
		const submitBtn = form.querySelector(
			'button[type="submit"]'
		) as HTMLButtonElement;

		// Capture UTM parameters on page load
		const urlParams = new URLSearchParams(window.location.search);
		const utmSource = urlParams.get("utm_source") || "";
		const utmMedium = urlParams.get("utm_medium") || "";
		const utmCampaign = urlParams.get("utm_campaign") || "";

		form.addEventListener("submit", async (e) => {
			e.preventDefault();
			errorEl.classList.add("hidden");

			const name = (
				form.querySelector("#voornaam") as HTMLInputElement
			).value.trim();
			const email = (
				form.querySelector("#email") as HTMLInputElement
			).value.trim();
			const landcode = (
				form.querySelector("#landcode") as HTMLSelectElement
			).value;
			const phoneLocalRaw = (
				form.querySelector("#telefoon") as HTMLInputElement
			).value.trim();

			// Validation
			if (!name) {
				errorEl.textContent = "Vul je voornaam in";
				errorEl.classList.remove("hidden");
				return;
			}
			if (!email) {
				errorEl.textContent = "Vul je e-mailadres in";
				errorEl.classList.remove("hidden");
				return;
			}
			if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
				errorEl.textContent = "Dit lijkt geen geldig e-mailadres";
				errorEl.classList.remove("hidden");
				return;
			}
			// Normaliseer telefoonnummer: strip alles behalve cijfers, haal evt.
			// leidende 0 weg (lokale notatie) en plak de gekozen landcode ervoor.
			const phoneDigits = phoneLocalRaw.replace(/\D/g, "").replace(/^0+/, "");
			if (phoneDigits.length < 8) {
				errorEl.textContent = "Vul een geldig telefoonnummer in";
				errorEl.classList.remove("hidden");
				return;
			}
			const phone = landcode + phoneDigits;

			// Loading state
			submitBtn.disabled = true;
			submitBtn.textContent = "Een moment…";

			try {
				await fetch(
					"https://n8n.reconnectnow.nl/webhook/crystal-challenge-optin",
					{
						method: "POST",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify({
							name,
							email,
							phone,
							source: "challenge_optin",
							utm_source: utmSource,
							utm_medium: utmMedium,
							utm_campaign: utmCampaign,
							timestamp: new Date().toISOString(),
						}),
						keepalive: true,
					}
				);
			} catch {
				// Don't block redirect on webhook failure
			}

			// Track generate_lead event before redirect
			const redirectUrl = "/je-pijn-is-echt/bedankt/";
			let hasRedirected = false;
			function doRedirect() {
				if (!hasRedirected) {
					hasRedirected = true;
					window.location.href = redirectUrl;
				}
			}

			// user_data voor Enhanced Conversions: rauwe e-mail/voornaam/telefoon mee
			// in de dataLayer. GTM hasht (SHA-256) pas in de tag en stuurt het
			// uitsluitend mee als ad_user_data-consent gegeven is — zie consent mode
			// in Layout.astro.
			window.dataLayer = window.dataLayer || [];
			window.dataLayer.push({
				event: "generate_lead",
				lead_source: "challenge_optin",
				user_data: {
					email: email.toLowerCase(),
					phone_number: phone,
					address: { first_name: name },
				},
				eventCallback: doRedirect,
				eventTimeout: 2000,
			});
			setTimeout(doRedirect, 2500);
		});
	});
</script>
