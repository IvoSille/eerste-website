---
import Layout from "../../layouts/Layout.astro";
import Button from "../../components/Button.astro";
import Footer from "../../components/Footer.astro";
import { Picture } from "astro:assets";
import foto1 from "../../assets/images/foto_1.jpg";
import portretCrystal from "../../assets/images/Portret Crystal 1.jpg";

// De vijf gevoels-uitkomsten — gerenderd als één samenhangend 5-dagen-pad.
const dagen = [
	{
		kop: "Je ziet het voor het eerst.",
		rest: "Niet alleen de pijn — ook alles wat je eromheen doet. En je voelt: hier zit ruimte die ik nooit zag.",
	},
	{
		kop: "Het lag nooit aan jou.",
		rest: "Niet aan je instelling, niet aan te weinig je best doen. Vandaag voel je dat je iets dóet bovenop de pijn — en dat dat geen schuld is.",
	},
	{
		kop: "Je krijgt grip op het moment zelf.",
		rest: "Als een golf opkomt, schiet je niet meer automatisch weg in angst. Voor het eerst kun je erbij blijven.",
	},
	{
		kop: "Je ontdekt dat aanwezig zijn iets anders is dan opgeven.",
		rest: "Zonder te forceren, zonder te negeren. Je merkt dat er meer ruimte ontstaat wanneer je niet voortdurend tegen je lichaam hoeft te vechten.",
	},
	{
		kop: "Je voelt dat er meer invloed mogelijk is dan je dacht.",
		rest: "Misschien is er niets opgelost — maar je bent niet meer op precies dezelfde plek als vijf dagen geleden.",
	},
];
---

<Layout
	title="Je pijn is echt — gratis 5-daagse challenge | Crystal Helder"
	description="Een gratis 5-daagse challenge via een besloten WhatsApp-kanaal, voor vrouwen die al jaren vechten tegen onbegrepen klachten in hun bekken of cyclus — en nergens echt gehoor vinden."
	includeCal={false}
>
	{/* DECORATIVE BACKGROUND BLOBS */}
	<div
		class="hidden md:block fixed top-0 left-0 w-full h-full overflow-hidden -z-10 pointer-events-none"
		aria-hidden="true"
	>
		<div
			class="absolute top-[-10%] right-[-5%] w-[600px] h-[600px] bg-[var(--color-brand-secondary)] rounded-full mix-blend-multiply filter blur-[120px] opacity-50"
		>
		</div>
		<div
			class="absolute top-[35%] left-[-10%] w-[520px] h-[520px] bg-[var(--color-brand-accent-light)] rounded-full mix-blend-multiply filter blur-[120px] opacity-40"
		>
		</div>
	</div>

	{/* HERO */}
	<section
		class="relative pt-12 pb-8 md:pt-24 md:pb-16 px-6 lg:px-8 max-w-7xl mx-auto flex flex-col-reverse lg:flex-row items-center gap-3 md:gap-12 lg:gap-0"
	>
		<div
			class="w-full lg:w-[55%] relative z-20 text-center lg:text-left mt-2 md:mt-8 lg:mt-0 xl:-mr-24 bg-white/80 lg:bg-transparent backdrop-blur-md lg:backdrop-blur-none p-5 md:p-6 lg:p-0 rounded-3xl lg:rounded-none"
		>
			<div
				class="inline-block px-4 py-2 rounded-full bg-[var(--color-brand-secondary)]/60 backdrop-blur-md border border-[var(--color-brand-secondary)] mb-3 md:mb-6 text-xs md:text-sm font-semibold tracking-widest uppercase text-[var(--color-brand-accent-hover)] shadow-sm"
			>
				Gratis 5-daagse challenge · voor vrouwen met onbegrepen bekken-,
				baarmoeder- of cyclusklachten
			</div>
			<h1
				class="text-3xl sm:text-4xl md:text-5xl lg:text-[3.75rem] xl:text-[4rem] font-bold mb-4 md:mb-6 text-[var(--color-brand-primary-text)] leading-tight md:leading-[1.08] tracking-tight drop-shadow-sm"
			>
				Je pijn is echt. Maar misschien draag je méér dan alleen de pijn.
			</h1>
			<p
				class="text-lg sm:text-xl md:text-2xl text-[var(--color-brand-muted)] mb-6 md:mb-8 max-w-xl mx-auto lg:mx-0 leading-relaxed"
			>
				Een gratis 5-daagse challenge via WhatsApp, voor vrouwen die al jaren
				vechten tegen onbegrepen klachten in hun bekken of cyclus — en nergens
				echt gehoor vinden. Vijf dagen waarin je ontdekt hoe angst, spanning en
				de strijd om je klachten soms zwaarder kunnen voelen dan de klacht zelf —
				zodat er meer ruimte ontstaat in je lichaam en je leven.
			</p>
			<div class="flex justify-center lg:justify-start">
				<Button
					href="#doe-mee"
					data-cta-location="hero"
					className="text-base md:text-lg px-8 py-4 md:px-10 md:py-5"
				>
					Ja, ik doe mee →
				</Button>
			</div>
			<p
				class="text-xs text-[var(--color-brand-muted)] mt-3 max-w-md mx-auto lg:mx-0"
			>
				Gratis · 10 min per dag · via WhatsApp · je telefoonnummer blijft
				afgeschermd
			</p>

			{/* Dag-strip — visualiseert "5-daagse" */}
			<div
				class="day-strip mt-6 md:mt-8 flex items-center justify-center lg:justify-start gap-0"
				aria-label="Vijf dagen, elke ochtend een bericht"
			>
				{[1, 2, 3, 4, 5].map((d) => (
					<>
						<span
							class="relative z-10 w-9 h-9 md:w-10 md:h-10 shrink-0 rounded-full bg-[var(--color-brand-accent)] text-white font-heading font-semibold text-sm flex items-center justify-center shadow-sm shadow-[var(--color-brand-accent)]/25 tabular-nums"
						>
							{d}
						</span>
						{d < 5 && (
							<span
								class="h-[2px] w-5 sm:w-7 md:w-9 bg-gradient-to-r from-[var(--color-brand-accent)] to-[var(--color-brand-accent-light)]"
								aria-hidden="true"
							></span>
						)}
					</>
				))}
			</div>
			<p
				class="mt-2 text-xs text-[var(--color-brand-muted)] text-center lg:text-left"
			>
				Vijf dagen · elke ochtend een kort bericht
			</p>
		</div>
		<div class="w-full lg:w-[50%] relative z-10">
			<div
				class="relative w-full max-w-[220px] sm:max-w-xs md:max-w-md mx-auto aspect-[3/4] sm:aspect-square md:aspect-square lg:aspect-[4/5]"
			>
				<div
					class="absolute inset-0 bg-gradient-to-tr from-[#E8D1C5] via-[#f0ddd4] to-[#fdfbf9] rounded-tl-[6rem] rounded-br-[6rem] rounded-tr-3xl rounded-bl-3xl shadow-2xl shadow-[var(--color-brand-accent)]/25 transform rotate-[-2deg] transition-transform duration-700 hover:rotate-0"
					aria-hidden="true"
				>
				</div>
				<Picture
					src={foto1}
					alt="Crystal Helder"
					widths={[320, 480, 640, 960]}
					sizes="(max-width: 640px) 220px, (max-width: 768px) 320px, (max-width: 1024px) 448px, 640px"
					class="absolute inset-0 w-full h-full object-cover rounded-tl-[6rem] rounded-br-[6rem] rounded-tr-3xl rounded-bl-3xl shadow-[0_20px_50px_-15px_rgba(200,102,77,0.4)]"
					style="object-position: center 20%;"
					fetchpriority="high"
					loading="eager"
				/>

				{/* Zwevende WhatsApp-bubbel-badge — laat het kanaal voelen */}
				<div
					class="hidden sm:block absolute -bottom-5 -left-4 md:-left-8 z-20 w-[15rem] md:w-[16.5rem] bg-white/95 backdrop-blur-md rounded-2xl rounded-bl-md p-3.5 shadow-[0_16px_40px_-12px_rgba(44,38,36,0.35)] border border-white"
				>
					<div class="flex items-center gap-2 mb-2">
						<span
							class="w-6 h-6 rounded-full bg-[var(--color-brand-sage)]/60 flex items-center justify-center shrink-0"
							aria-hidden="true"
						>
							<svg
								class="w-3.5 h-3.5 text-[var(--color-brand-accent-hover)]"
								viewBox="0 0 24 24"
								fill="currentColor"
							>
								<path
									d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38c1.45.79 3.08 1.21 4.74 1.21 5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm0 1.67c2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.42 5.82c0 4.54-3.7 8.24-8.25 8.24-1.48 0-2.93-.4-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.18 8.18 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.25-8.24zm-3.6 4.43c-.17 0-.45.06-.69.31-.24.25-.91.89-.91 2.18 0 1.28.93 2.52 1.06 2.7.13.17 1.83 2.79 4.43 3.91.62.27 1.1.43 1.48.55.62.2 1.19.17 1.64.1.5-.07 1.54-.63 1.76-1.24.22-.61.22-1.13.15-1.24-.07-.11-.24-.17-.5-.3-.26-.13-1.54-.76-1.78-.85-.24-.09-.41-.13-.59.13-.17.25-.67.85-.83 1.02-.15.17-.3.19-.56.06-.26-.13-1.1-.41-2.1-1.3-.78-.69-1.3-1.55-1.45-1.81-.15-.26-.02-.4.11-.53.12-.12.26-.3.4-.46.13-.15.17-.26.26-.43.09-.17.04-.32-.02-.45-.06-.13-.59-1.42-.81-1.94-.21-.51-.43-.44-.59-.45-.15-.01-.32-.01-.5-.01z"
								></path>
							</svg>
						</span>
						<span
							class="text-[0.7rem] font-semibold text-[var(--color-brand-primary-text)] leading-tight"
							>Crystal · besloten kanaal</span
						>
					</div>
					<p
						class="text-[0.8rem] text-[var(--color-brand-primary-text)] leading-snug"
					>
						Goedemorgen. Vandaag iets kleins — tien minuten, meer niet.
					</p>
					<p
						class="text-[0.65rem] text-[var(--color-brand-muted)] text-right mt-1 tabular-nums"
					>
						08:01
					</p>
				</div>
			</div>
		</div>
	</section>

	{/* SECTIE 1 — DE SCÈNE (herkenning vóór alles) */}
	<section class="py-14 md:py-20 px-6 lg:px-8 bg-gradient-to-b from-[var(--color-brand-accent-light)]/10 to-white fade-in-section">
		<div class="max-w-3xl mx-auto">
			<div
				class="text-lg md:text-xl text-[var(--color-brand-muted)] leading-relaxed space-y-6"
			>
				<p>
					Het is geen goede dag. Je voelde het vanochtend al toen je wakker
					werd.
				</p>
				<p class="italic">
					Hoe erg is het vandaag?<br />
					Waar zit het?<br />
					Wordt dit zo'n dag?
				</p>
				<p>Je agenda schiet door je hoofd.</p>
				<p class="italic">
					Kan die afspraak vanmiddag nog?<br />
					Hoe lang moet ik zitten?<br />
					Waar is het dichtstbijzijnde toilet?<br />
					Heb ik iets tegen de pijn bij me?
				</p>
				<p>Je gaat toch.</p>
				<p>
					Je lacht.<br />
					Je functioneert.<br />
					Niemand merkt hoeveel energie er gaat naar normaal doen.
				</p>
				<p>
					Bij de huisarts heb je het zó vaak uitgelegd. De pil mee. Een
					paracetamol. "Kijk het nog maar even aan." En die ene zin die je niet
					meer uit je hoofd krijgt: <em class="italic"
						>het zit waarschijnlijk tussen je oren.</em
					>
				</p>
				<p>
					Misschien kreeg je een naam.<br />
					Misschien juist niet.
				</p>
				<p>Maar ergens onderweg ben je iets anders kwijtgeraakt.</p>
				<p
					class="text-xl md:text-2xl font-semibold text-[var(--color-brand-primary-text)] not-italic"
				>
					Vertrouwen.
				</p>
				<p>
					En tegelijk weet je, dieper dan welke uitslag ook: dit is echt. Je
					voelt het. Elke keer weer.
				</p>
				<p>
					Op een verjaardag zegt iemand: "Je ziet er anders prima uit, hoor." Ze
					zien een gewone vrouw. Ze zien niet hoe je je dag plant rond de
					volgende pijngolf. Hoe je je schrap zet, nog voor het begint.
				</p>
				<p>Niemand ziet dat. En dat maakt het dubbel zo zwaar.</p>
				<p
					class="text-xl md:text-2xl font-semibold text-[var(--color-brand-primary-text)] not-italic"
				>
					Herken je dit? Dan is deze challenge voor jou.
				</p>
			</div>
			<div class="mt-10 md:mt-12 flex justify-center">
				<Button
					href="#doe-mee"
					data-cta-location="de-scene"
					className="text-base md:text-lg px-8 py-4 md:px-10 md:py-5"
				>
					Ja, ik doe mee →
				</Button>
			</div>
		</div>
	</section>

	{/* SECTIE 2 — DE SPIEGEL (de belofte, voelbaar zonder claim) */}
	<section
		class="bg-gradient-to-b from-[var(--color-brand-accent-light)]/15 via-[var(--color-brand-accent-light)]/30 to-[var(--color-brand-accent-light)]/15 py-14 md:py-20 px-6 lg:px-8 fade-in-section"
	>
		<div class="max-w-3xl mx-auto">
			<div
				class="text-lg md:text-xl text-[var(--color-brand-muted)] leading-relaxed space-y-6"
			>
				<p>
					De pijn verdwijnt niet in vijf dagen. Dat beloof ik je niet — daar heb
					je al genoeg lege beloftes over gehad.
				</p>
				<p
					class="text-xl md:text-2xl font-semibold text-[var(--color-brand-primary-text)]"
				>
					Maar hoe jij erin staat, dat verschuift wél.
				</p>
				<p>
					Dezelfde dag. Dezelfde kruik. Misschien dezelfde golf die opkomt.
				</p>
				<p>
					En toch sta je er anders bij. Je merkt dat je je niet meteen schrap
					zet. Dat de paniek — <em class="italic"
						>wordt dit erger? stopt dit ooit?</em
					> — niet automatisch de regie pakt.
				</p>
				<p>
					Voor het eerst voel je: ik ben hier niet volledig aan overgeleverd. Ik
					heb meer ruimte dan ik dacht.
				</p>
				<p>
					Dat is wat ik je deze vijf dagen wil laten voelen. Geen "denk
					positiever". Iets dat je in je eigen lijf merkt.
				</p>
			</div>
			<div class="mt-10 md:mt-12 flex justify-center">
				<Button
					href="#doe-mee"
					data-cta-location="de-spiegel"
					className="text-base md:text-lg px-8 py-4 md:px-10 md:py-5"
				>
					Ik wil dat voelen →
				</Button>
			</div>
		</div>
	</section>

	{/* SECTIE 3 — DE GNM-BRUG */}
	<section class="py-14 md:py-20 px-6 lg:px-8 bg-gradient-to-b from-[var(--color-brand-sage)]/10 via-[var(--color-brand-sage)]/30 to-[var(--color-brand-sage)]/10 fade-in-section">
		<div class="max-w-3xl mx-auto">
			<h2
				class="text-3xl sm:text-4xl md:text-5xl font-semibold leading-tight tracking-tight mb-6 md:mb-8 text-center"
			>
				Misschien heb je al eens van Germaanse geneeskunde gehoord.
			</h2>
			<div
				class="text-lg md:text-xl text-[var(--color-brand-muted)] leading-relaxed space-y-6"
			>
				<p>
					Misschien kwam je hier via iemand die er warm voor is. Of misschien
					zegt de term je nog niets — dat hoeft ook niet.
				</p>
				<p>
					Want deze vijf dagen gaan niet over een methode die je moet snappen. Ze
					gaan niet over begrijpen waaróm je lichaam dit doet — hoe waardevol dat
					ook is, dat is werk voor later, samen, in alle rust.
				</p>
				<p>
					Deze week doen we iets anders. We zakken van je hoofd naar je lijf. Je
					hoeft niets te weten, niets te geloven, geen theorie te leren. Je gaat
					alleen iets vóélen verschuiven in hoe je met je pijn omgaat. Daar heb je
					geen voorkennis voor nodig — alleen vijf dagen en een beetje
					nieuwsgierigheid.
				</p>
			</div>
		</div>
	</section>

	{/* SECTIE 4 — WAT DE CHALLENGE IS */}
	<section class="py-14 md:py-20 px-6 lg:px-8 fade-in-section">
		<div class="max-w-4xl mx-auto">
			<h2
				class="text-3xl sm:text-4xl md:text-5xl font-semibold leading-tight tracking-tight mb-6 md:mb-8 text-center"
			>
				De challenge "Je pijn is echt" — 5 dagen, via WhatsApp
			</h2>
			<div
				class="max-w-3xl mx-auto text-lg md:text-xl text-[var(--color-brand-muted)] leading-relaxed space-y-6 mb-12 md:mb-16"
			>
				<p>
					Vijf dagen lang stuur ik je elke ochtend een kort, persoonlijk bericht
					in een besloten WhatsApp-kanaal. Eerlijk, rustig, recht uit mijn
					praktijk en mijn eigen leven.
				</p>
				<p>
					Elke dag één inzicht en één kleine oefening. Tien tot vijftien minuten,
					meer niet. Geen werkboek, geen huiswerkberg, geen extra ding op je
					to-do lijst dat je toch niet redt. Je bent al moe genoeg.
				</p>
			</div>

			{/* WhatsApp-bericht-motief — laat het kanaal voelen (op-merk, geen WhatsApp-groen) */}
			<div class="max-w-md mx-auto mb-14 md:mb-20">
				<div
					class="bg-[var(--color-brand-base)] border border-white rounded-[1.5rem] p-4 md:p-5 shadow-xl shadow-[var(--color-brand-muted)]/10"
				>
					<div
						class="flex items-center gap-2.5 pb-3 mb-4 border-b border-[var(--color-brand-secondary)]/70"
					>
						<span
							class="w-9 h-9 rounded-full bg-[var(--color-brand-sage)]/60 flex items-center justify-center shrink-0"
							aria-hidden="true"
						>
							<svg
								class="w-5 h-5 text-[var(--color-brand-accent-hover)]"
								viewBox="0 0 24 24"
								fill="currentColor"
							>
								<path
									d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38c1.45.79 3.08 1.21 4.74 1.21 5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm0 1.67c2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.42 5.82c0 4.54-3.7 8.24-8.25 8.24-1.48 0-2.93-.4-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.18 8.18 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.25-8.24zm-3.6 4.43c-.17 0-.45.06-.69.31-.24.25-.91.89-.91 2.18 0 1.28.93 2.52 1.06 2.7.13.17 1.83 2.79 4.43 3.91.62.27 1.1.43 1.48.55.62.2 1.19.17 1.64.1.5-.07 1.54-.63 1.76-1.24.22-.61.22-1.13.15-1.24-.07-.11-.24-.17-.5-.3-.26-.13-1.54-.76-1.78-.85-.24-.09-.41-.13-.59.13-.17.25-.67.85-.83 1.02-.15.17-.3.19-.56.06-.26-.13-1.1-.41-2.1-1.3-.78-.69-1.3-1.55-1.45-1.81-.15-.26-.02-.4.11-.53.12-.12.26-.3.4-.46.13-.15.17-.26.26-.43.09-.17.04-.32-.02-.45-.06-.13-.59-1.42-.81-1.94-.21-.51-.43-.44-.59-.45-.15-.01-.32-.01-.5-.01z"
								></path>
							</svg>
						</span>
						<div class="leading-tight">
							<p
								class="text-sm font-semibold text-[var(--color-brand-primary-text)]"
							>
								Crystal · besloten kanaal
							</p>
							<p class="text-xs text-[var(--color-brand-muted)]">
								jij leest mee — niemand ziet of jij reageert
							</p>
						</div>
					</div>
					<div
						class="chat-bubble relative bg-white rounded-2xl rounded-tl-md p-3.5 shadow-sm shadow-[var(--color-brand-muted)]/10 max-w-[90%]"
					>
						<p
							class="text-[0.95rem] text-[var(--color-brand-primary-text)] leading-snug"
						>
							Goedemorgen. Vandaag iets kleins — geen huiswerk, geen theorie. Even
							tien minuten met je lijf. Klaar voor je je koffie ophebt.
						</p>
						<p
							class="text-[0.65rem] text-[var(--color-brand-muted)] text-right mt-1 tabular-nums"
						>
							08:01
						</p>
					</div>
				</div>
				<p class="text-center text-sm text-[var(--color-brand-muted)] mt-3">
					Zo voelt een ochtend in de challenge.
				</p>
			</div>

			<p
				class="text-xl md:text-2xl font-semibold text-[var(--color-brand-primary-text)] text-center mb-10 md:mb-12"
			>
				Dit is wat er in vijf dagen verschuift:
			</p>

			{/* 5-dagen-pad — de vijf uitkomsten als één samenhangende reis */}
			<ol class="relative max-w-2xl mx-auto">
				{dagen.map((dag, i) => (
					<li class="flex gap-4 md:gap-6">
						{/* Rail: dag-knoop + verbindingslijn */}
						<div class="flex flex-col items-center">
							<span
