---
import Layout from "../../layouts/Layout.astro";
import Button from "../../components/Button.astro";
---

<Layout
	title="Je staat op de wachtlijst — Crystal Helder"
	description="Je staat op de wachtlijst voor het groepsprogramma Thuiskomen in je Vrouwenlijf."
	includeCal={false}
>
	<div class="min-h-screen flex items-center justify-center px-6 py-24 relative overflow-hidden">
		{/* Background blobs */}
		<div class="fixed top-0 left-0 w-full h-full overflow-hidden -z-10 pointer-events-none">
			<div class="absolute top-[-10%] right-[-5%] w-[400px] h-[400px] bg-[var(--color-brand-secondary)] rounded-full mix-blend-multiply filter blur-[80px] opacity-70"></div>
			<div class="absolute bottom-[-10%] left-[-5%] w-[350px] h-[350px] bg-[var(--color-brand-sage)] rounded-full mix-blend-multiply filter blur-[100px] opacity-50"></div>
		</div>

		<div class="max-w-2xl mx-auto text-center">
			{/* Checkmark circle */}
			<div class="w-24 h-24 rounded-full bg-[var(--color-brand-sage)] flex items-center justify-center mx-auto mb-10 shadow-lg shadow-[var(--color-brand-sage)]/30">
				<svg class="w-12 h-12 text-[var(--color-brand-primary-text)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
					<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
				</svg>
			</div>

			<div class="inline-block px-4 py-2 rounded-full bg-white/80 backdrop-blur-md border border-white mb-6 text-xs font-semibold tracking-widest uppercase text-[var(--color-brand-accent)] shadow-sm">
				Wachtlijst
			</div>

			<h1 class="text-4xl md:text-6xl font-bold mb-6 text-[var(--color-brand-primary-text)] leading-tight">
				Fijn dat je erbij <span class="text-[var(--color-brand-accent)]">wilt zijn!</span>
			</h1>

			<p class="text-lg md:text-xl text-[var(--color-brand-muted)] mb-12 leading-relaxed max-w-xl mx-auto">
				Je staat op de wachtlijst. Ik stuur je bericht zodra het programma opengaat. Wil je in de tussentijd meer weten?
			</p>

			<Button href="https://crystalhelder.nl" className="text-lg px-10 py-5">
				Kijk op crystalhelder.nl
			</Button>
		</div>
	</div>

	{/* FOOTER */}
	<footer class="py-8 px-6 text-center">
		<p class="text-xs md:text-sm text-[var(--color-brand-muted)]">
			Crystal Helder · Tienhoven, Utrecht · <a href="https://crystalhelder.nl" class="underline hover:text-[var(--color-brand-accent)] transition-colors duration-300">crystalhelder.nl</a>
		</p>
	</footer>
</Layout>
