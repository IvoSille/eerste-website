---
import Layout from "../../layouts/Layout.astro";
import Button from "../../components/Button.astro";
import { Image } from "astro:assets";
import fotoCrystal from "../../assets/images/foto_bedankt.jpg";
---

<Layout
	title="Thuiskomen in je Vrouwenlijf — Wachtlijst"
	description="Schrijf je in voor de wachtlijst van het 12-weken groepsprogramma 'Thuiskomen in je Vrouwenlijf' door Crystal Helder."
	includeCal={false}
>
	{/* DECORATIVE BACKGROUND BLOBS */}
	<div
		class="hidden md:block fixed top-0 left-0 w-full h-full overflow-hidden -z-10 pointer-events-none"
	>
		<div
			class="absolute top-[-10%] right-[-5%] w-[600px] h-[600px] bg-[var(--color-brand-secondary)] rounded-full mix-blend-multiply filter blur-[120px] opacity-50"
		></div>
		<div
			class="absolute top-[40%] left-[-10%] w-[500px] h-[500px] bg-[var(--color-brand-sage)] rounded-full mix-blend-multiply filter blur-[120px] opacity-30"
		></div>
	</div>

	{/* SECTIE 1 — HERO */}
	<section class="relative pt-16 pb-12 md:pt-28 md:pb-20 px-6 lg:px-8">
		<div class="max-w-4xl mx-auto text-center">
			<div class="inline-block px-4 py-2 rounded-full bg-[var(--color-brand-secondary)]/60 backdrop-blur-md border border-[var(--color-brand-secondary)] mb-4 md:mb-6 text-xs md:text-sm font-semibold tracking-widest uppercase text-[var(--color-brand-accent)] shadow-sm">
				Binnenkort
			</div>
			<h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-[5rem] font-bold mb-5 md:mb-8 text-[var(--color-brand-primary-text)] leading-none md:leading-[1.05] tracking-tight">
				Al jaren klachten aan baarmoeder, cyclus, vulva of borsten — en niemand die het <span class="text-[var(--color-brand-accent)] italic">écht</span> snapt?
			</h1>
			<p class="text-lg sm:text-xl md:text-2xl text-[var(--color-brand-muted)] max-w-3xl mx-auto leading-relaxed">
				Je hebt alles geprobeerd. Artsen, specialisten, echo's, bloedonderzoek. Steeds hetzelfde antwoord: "We kunnen niets vinden" of "Het zit tussen je oren." Maar jij voelt dat er wél iets is.
			</p>
		</div>
	</section>

	{/* SECTIE 2 — DE BELOFTE */}
	<section class="py-20 md:py-28 px-6 lg:px-8 bg-white fade-in-section">
		<div class="max-w-4xl mx-auto text-center">
			<h2 class="text-3xl sm:text-4xl md:text-5xl font-semibold leading-tight tracking-tight mb-6 md:mb-8">
				Er is een reden waarom je lichaam dit doet
			</h2>
			<p class="text-lg md:text-xl text-[var(--color-brand-muted)] leading-relaxed max-w-3xl mx-auto">
				En die reden is te begrijpen. In "Thuiskomen in je Vrouwenlijf" — een 12-weken groepsprogramma — leer je eindelijk wat geen enkele arts je kon vertellen: waarom je lichaam dit doet, hoe je klachten draagbaar worden of verdwijnen, en hoe je weer thuiskomt in je vrouwenlijf, je cyclus en je intimiteit.
			</p>
		</div>
	</section>

	{/* SECTIE 3 — HERKENNINGSPUNTEN */}
	<section class="py-20 md:py-28 px-6 lg:px-8 fade-in-section">
		<div class="max-w-4xl mx-auto">
			<h2 class="text-3xl sm:text-4xl md:text-5xl font-semibold leading-tight tracking-tight mb-8 md:mb-12 text-center">
				Herken je dit?
			</h2>
			<ul class="space-y-5 max-w-2xl mx-auto">
				{[
					"Je hebt een medische odyssee achter de rug — en nog steeds geen antwoorden",
					"Je bent bang dat het \"tussen je oren\" zit, maar je lichaam zegt iets anders",
					"Je hebt het gevoel dat je niet serieus genomen wordt",
					"Je bent moe van het zoeken en wilt eindelijk begrijpen wat er aan de hand is",
					"Intimiteit, je cyclus of je vrouwenlijf voelen als een strijdtoneel",
				].map((item) => (
					<li class="flex items-start text-lg text-[var(--color-brand-primary-text)]">
						<div class="w-6 h-6 rounded-full bg-[var(--color-brand-secondary)] flex items-center justify-center mr-4 mt-0.5 shrink-0">
							<svg class="h-3 w-3 text-[var(--color-brand-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
						</div>
						<span>{item}</span>
					</li>
				))}
			</ul>
		</div>
	</section>

	{/* SECTIE 4 — OVER CRYSTAL */}
	<section class="py-20 md:py-28 px-6 lg:px-8 bg-white fade-in-section">
		<div class="max-w-4xl mx-auto flex flex-col items-center text-center">
			<div class="w-40 h-40 md:w-48 md:h-48 rounded-full overflow-hidden shrink-0 border-4 border-[var(--color-brand-accent)]/80 mb-6 shadow-lg">
				<Image
					src={fotoCrystal}
					alt="Crystal Helder"
					class="w-full h-full object-cover"
					style="object-position: center 20%;"
				/>
			</div>
			<h2 class="text-3xl sm:text-4xl md:text-5xl font-semibold leading-tight tracking-tight mb-2">
				Crystal Helder
			</h2>
			<p class="text-base md:text-lg text-[var(--color-brand-accent)] font-medium mb-6">
				Expert in de Germaanse geneeskunde
			</p>
			<p class="text-lg md:text-xl text-[var(--color-brand-muted)] leading-relaxed max-w-2xl">
				Ik begeleid vrouwen met onbegrepen klachten aan baarmoeder, cyclus, vulva of borsten. Als één van circa 30 opgeleide practitioners in de Germaanse geneeskunde in Nederland help ik je begrijpen waarom je lichaam doet wat het doet.
			</p>
		</div>
	</section>

	{/* SECTIE 5 — WACHTLIJST FORMULIER */}
	<section id="wachtlijst" class="py-20 md:py-28 px-6 lg:px-8 bg-gradient-to-b from-[var(--color-brand-base)] via-[#f4ebe6] to-[var(--color-brand-secondary)] fade-in-section">
		<div class="max-w-xl mx-auto">
			<div class="bg-white/70 backdrop-blur-xl border border-white rounded-[2rem] md:rounded-[3rem] p-8 md:p-12 shadow-xl shadow-[var(--color-brand-muted)]/5">
				<h2 class="text-3xl sm:text-4xl font-semibold leading-tight tracking-tight mb-4 text-center">
					Zet me op de wachtlijst
				</h2>
				<p class="text-base md:text-lg text-[var(--color-brand-muted)] leading-relaxed mb-8 text-center">
					Het programma start binnenkort. Schrijf je in en ik stuur je als eerste bericht wanneer je je kunt aanmelden. Geen spam, alleen updates over het programma.
				</p>

				<form id="waitlist-form" class="space-y-5" novalidate>
					<div>
						<label for="voornaam" class="block text-sm font-semibold text-[var(--color-brand-primary-text)] mb-2">Voornaam</label>
						<input
							type="text"
							id="voornaam"
							name="voornaam"
							required
							autocomplete="given-name"
							class="w-full rounded-xl border border-[var(--color-brand-secondary)] px-4 py-3 bg-white text-[var(--color-brand-primary-text)] placeholder:text-[var(--color-brand-muted)]/50 focus:ring-2 focus:ring-[var(--color-brand-accent)] focus:border-transparent outline-none transition-all duration-300"
							placeholder="Je voornaam"
						/>
					</div>
					<div>
						<label for="email" class="block text-sm font-semibold text-[var(--color-brand-primary-text)] mb-2">E-mailadres</label>
						<input
							type="email"
							id="email"
							name="email"
							required
							autocomplete="email"
							class="w-full rounded-xl border border-[var(--color-brand-secondary)] px-4 py-3 bg-white text-[var(--color-brand-primary-text)] placeholder:text-[var(--color-brand-muted)]/50 focus:ring-2 focus:ring-[var(--color-brand-accent)] focus:border-transparent outline-none transition-all duration-300"
							placeholder="je@email.nl"
						/>
					</div>
					<p id="form-error" class="text-[var(--color-brand-accent)] text-sm hidden"></p>
					<Button type="submit" className="w-full text-base md:text-lg py-4 cursor-pointer">
						Ja, houd me op de hoogte
					</Button>
				</form>
			</div>
		</div>
	</section>

	{/* FOOTER */}
	<footer class="py-8 px-6 text-center">
		<p class="text-xs md:text-sm text-[var(--color-brand-muted)]">
			Crystal Helder · Tienhoven, Utrecht · <a href="https://crystalhelder.nl" class="underline hover:text-[var(--color-brand-accent)] transition-colors duration-300">crystalhelder.nl</a>
		</p>
	</footer>
</Layout>

<style is:global>
	/* Scroll Animation — only hide when JS is confirmed available */
	:global(html.js) .fade-in-section {
		opacity: 0;
		transform: translateY(20px);
		visibility: hidden;
		transition: opacity 600ms ease-out, transform 600ms ease-out;
		will-change: opacity, visibility, transform;
	}
	:global(html.js) .fade-in-section.is-visible {
		opacity: 1;
		transform: none;
		visibility: visible;
	}
</style>

<script>
	// Scroll animation observer
	document.addEventListener("DOMContentLoaded", () => {
		const observer = new IntersectionObserver(
			(entries, obs) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add("is-visible");
						obs.unobserve(entry.target);
					}
				});
			},
			{ threshold: 0.15 }
		);
		document.querySelectorAll(".fade-in-section").forEach((el) => observer.observe(el));
	});

	// Scroll depth tracking
	document.addEventListener("DOMContentLoaded", () => {
		const thresholds = [25, 50, 75, 90];
		const fired = new Set<number>();

		const checkScroll = () => {
			const scrollTop = window.scrollY;
			const docHeight = document.documentElement.scrollHeight - window.innerHeight;
			if (docHeight <= 0) return;
			const scrollPercent = Math.round((scrollTop / docHeight) * 100);

			thresholds.forEach((threshold) => {
				if (scrollPercent >= threshold && !fired.has(threshold)) {
					fired.add(threshold);
					window.dataLayer = window.dataLayer || [];
					window.dataLayer.push({
						event: "scroll_depth",
						scroll_percentage: threshold,
					});
				}
			});
		};

		let ticking = false;
		window.addEventListener(
			"scroll",
			() => {
				if (!ticking) {
					window.requestAnimationFrame(() => {
						checkScroll();
						ticking = false;
					});
					ticking = true;
				}
			},
			{ passive: true }
		);
	});

	// Waitlist form submission
	document.addEventListener("DOMContentLoaded", () => {
		const form = document.getElementById("waitlist-form") as HTMLFormElement;
		const errorEl = document.getElementById("form-error") as HTMLElement;
		const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
		const originalText = submitBtn.textContent;

		form.addEventListener("submit", async (e) => {
			e.preventDefault();
			errorEl.classList.add("hidden");

			const name = (form.querySelector("#voornaam") as HTMLInputElement).value.trim();
			const email = (form.querySelector("#email") as HTMLInputElement).value.trim();

			// Client-side validation
			if (!name) {
				errorEl.textContent = "Vul je voornaam in.";
				errorEl.classList.remove("hidden");
				return;
			}
			if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
				errorEl.textContent = "Vul een geldig e-mailadres in.";
				errorEl.classList.remove("hidden");
				return;
			}

			// Loading state
			submitBtn.disabled = true;
			submitBtn.textContent = "Even geduld...";

			try {
				// Send to n8n webhook (fire-and-forget pattern)
				// TODO: Replace with actual n8n webhook URL once workflow is created
				const webhookUrl = "https://n8n.reconnectnow.nl/webhook/wachtlijst";
				await fetch(webhookUrl, {
					method: "POST",
					headers: { "Content-Type": "application/json" },
					body: JSON.stringify({
						name,
						email,
						source: "wachtlijst",
						timestamp: new Date().toISOString(),
					}),
					keepalive: true,
				});
			} catch {
				// Don't block redirect on webhook failure
			}

			// Track generate_lead event before redirect
			const redirectUrl = "/wachtlijst/bedankt/";
			let hasRedirected = false;
			function doRedirect() {
				if (!hasRedirected) {
					hasRedirected = true;
					window.location.href = redirectUrl;
				}
			}

			window.dataLayer = window.dataLayer || [];
			window.dataLayer.push({
				event: "generate_lead",
				lead_source: "wachtlijst",
				eventCallback: doRedirect,
				eventTimeout: 2000,
			});
			setTimeout(doRedirect, 2500);
		});
	});
</script>
